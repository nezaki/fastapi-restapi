{
  "name": "fastapi-restapi",
  "image": "mcr.microsoft.com/devcontainers/python:3.14",
  "postCreateCommand": "pip install uv && uv sync",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "forwardPorts": [8000]
}
